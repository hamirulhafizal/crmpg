// Copy to Secrets.xcconfig and fill in values from the web repo .env
// NEVER commit Secrets.xcconfig to git

SUPABASE_URL = https:/$()/your-project.supabase.co
SUPABASE_ANON_KEY = your-anon-key
API_BASE_URL = https:/$()/www.publicgolds.com
GOOGLE_IOS_CLIENT_ID = your-ios-oauth-client-id.apps.googleusercontent.com
