{
  "manifest_version": 3,
  "name": "CRMPG by KEM",
  "description": "Extension for KEM Public Gold Dealers to download their customer data's from business center page.",
  "version": "1.0.0",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "identity"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.pgmall.my/*"
      ],
      "js": [
        "jquery.min.js",
        "xlsx.full.min.js",
        "background.js"
      ],
      "run_at": "document_end"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    },
    "default_title": "CRMPG by KEM",
    "default_popup": "background.html"
  }
}